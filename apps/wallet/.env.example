# Clerk (auth) — same SSO config as apps/rough-cut per ADR 0001
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Database (Neon, shared with apps/rough-cut via @repo/db)
DATABASE_URL=

# Vercel Cron — /api/cron/autorecharge and /api/cron/cleanup check this
# Bearer token; Vercel sets it automatically for scheduled invocations once
# this var exists on the project.
CRON_SECRET=

# Stripe — sole billing authority for the ecosystem (ADR 0001). Bundle
# prices/amounts live in the Stripe dashboard; STRIPE_PRICE_IDS is the
# allowlist of Price IDs this app will sell.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_IDS=
STRIPE_WEBHOOK_SECRET=

# Upstash Redis (Vercel KV) — per-user rate limiting.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=

# Cross-app URL: where apps/rough-cut is deployed, so Stripe Checkout's
# success/cancel URLs redirect back to it. Validated in src/lib/env.ts —
# required in production, defaults to http://localhost:3000 in dev
# (rough-cut's dev port is pinned to 3000).
# NOTE: must be spelled exactly NEXT_PUBLIC_ROUGH_CUT_URL (not
# NEXT_ROUGH_CUT_URL) or env.ts silently falls back to localhost in dev and
# throws at build time in production.
NEXT_PUBLIC_ROUGH_CUT_URL=

# Sentry (optional — no-op until set)
# NEXT_PUBLIC_SENTRY_DSN=
