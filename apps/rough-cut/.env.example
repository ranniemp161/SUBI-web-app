# Clerk (auth)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Database (Neon, shared with apps/wallet via @repo/db)
DATABASE_URL=

# Deepgram (transcription)
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=
# Optional: caps Deepgram uploads (bytes). Defaults to 2GB if unset.
# DEEPGRAM_MAX_UPLOAD_BYTES=

# Vercel Blob (direct browser upload + delete-after-transcription)
BLOB_READ_WRITE_TOKEN=

# Gemini (AI Cut suggestions)
GEMINI_API_KEY=

# Upstash Redis (Vercel KV) — per-user rate limiting. Required in production;
# in dev, missing values just disable rate limiting (see lib/rate-limit.ts).
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=

# Vercel Cron — /api/cron/blob-sweep checks this Bearer token; Vercel sets it
# automatically for scheduled invocations once this var exists on the project.
CRON_SECRET=

# Cross-app URL: where apps/wallet is deployed, so "Buy Credits" links there.
# Validated in src/lib/env.ts — required in production, defaults to
# http://localhost:3001 in dev (wallet's dev port is pinned to 3001).
NEXT_PUBLIC_WALLET_URL=

# Local-dev-only: overrides the Deepgram callback base URL so a public tunnel
# (e.g. `cloudflared tunnel`) can receive the real async callback instead of
# falling back to synchronous transcription. Leave unset in production — the
# request's own origin is used instead. See deepgram/route.ts.
# PUBLIC_APP_URL=

# Vercel Deployment Protection — only needed if "Vercel Authentication" is
# enabled on the project. Without it, Deepgram's callback can't reach us and
# transcription hangs at "processing" forever. Generate via Project Settings
# -> Deployment Protection -> Protection Bypass for Automation; Vercel injects
# this automatically once configured, no manual copy needed.
# VERCEL_AUTOMATION_BYPASS_SECRET=

# Sentry (optional — no-op until set)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=

# Credits (optional overrides — see lib/credits.ts for defaults)
# RETAIL_MICROS_PER_MINUTE=
# MEMBER_MONTHLY_GRANT_SECONDS=

# Only this exact email gets the automatic monthly credit grant on
# provisioning (see lib/users.ts) — everyone else pays via Stripe. Required;
# without it, no one gets free credits (isAllowlistedMember returns false).
MEMBER_ALLOWLIST_EMAIL=

# Pusher (WebSockets for real-time status updates)
PUSHER_APP_ID=
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_CLUSTER=
